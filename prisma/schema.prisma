// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  CLINIC_ADMIN
  VET
  RECEPTIONIST
  GROOMER
  INVENTORY
  ADOPTION_MANAGER
  CLIENT
}

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum PetSpecies {
  DOG
  CAT
  BIRD
  RABBIT
  HAMSTER
  REPTILE
  OTHER
}

enum PetSex {
  MALE
  FEMALE
}

enum AppointmentType {
  CONSULTATION
  VACCINATION
  AESTHETICS
  SURGERY
  CHECKUP
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum VaccinationStatus {
  SCHEDULED
  ADMINISTERED
  OVERDUE
}

enum SurgeryStatus {
  SCHEDULED
  PRE_OP
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AestheticStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AdoptionStatus {
  AVAILABLE
  PENDING
  APPROVED
  REJECTED
  ADOPTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
  BUY_X_GET_Y  // ej: 2x1, 3x2 (compra X, lleva Y gratis)
}

// ─── Pasaporte médico · consentimiento entre clínicas ─────────────────────────

enum ConsentStatus {
  PENDING   // creado pero aún no activado (reservado para futuro flujo con confirmación)
  GRANTED   // activo: la clínica destino puede leer
  REVOKED   // revocado por el dueño; terminal
  EXPIRED   // pasó la fecha de expiración; terminal
}

enum ConsentScope {
  PASSPORT_READ        // lectura del pasaporte agregado (recomendado por defecto)
  MEDICAL_RECORDS_READ // lectura de medical records crudos (solo staff veterinario)
}

enum ConsentAuditAction {
  CREATED
  GRANTED
  REVOKED
  ACCESSED
  SHARE_CREATED
  SHARE_REVOKED
  SHARE_ACCESSED
  EXPIRED
}

enum DiscountTargetType {
  PRODUCT           // producto específico
  PRODUCT_CATEGORY  // todos los productos de una categoría
  SERVICE           // tipo de servicio (AppointmentType)
  ALL_PRODUCTS      // todos los productos
  ALL_SERVICES      // todos los servicios
}

enum ConsentTokenScope {
  READ   // lectura del pasaporte y registros médicos del/los pet(s) autorizados
  FULL   // lectura + acciones permitidas (p.ej. agendar cita, crear orden); uso futuro
}

enum ConsentTokenStatus {
  ACTIVE    // token vigente, puede ser usado para acceder
  REVOKED   // revocado por el dueño; terminal
  EXPIRED   // pasó la fecha de expiración; terminal
}

enum ConsentAccessAction {
  VALIDATE  // el portador del token intentó validar/canjearlo
  READ      // lectura efectiva de datos protegidos
  REVOKE    // acción administrativa de revocación
}

// ─── Fase 2 · Membresías (monetización recurrente) ───────────────────────────

enum MembershipBillingPeriod {
  MONTHLY
  ANNUAL
}

enum MembershipSubscriptionStatus {
  PENDING    // creada, sin pago confirmado aún
  ACTIVE     // vigente y generando beneficios
  PAUSED     // suspendida temporalmente por el dueño
  CANCELLED  // cancelada por el dueño; sigue vigente hasta fin del período actual
  EXPIRED    // terminó el período sin renovación
  PAST_DUE   // el último intento de cobro falló (el BillingProvider reintentará)
}

enum BillingAttemptStatus {
  PENDING   // intento en curso
  SUCCESS   // cobrado
  FAILED    // rechazado; failureCode/failureMessage disponibles
}

enum BillingProviderKind {
  MOCK       // implementación de prueba, no toca red
  STRIPE     // implementación futura
  PAYPHONE   // implementación futura (preferente para Ecuador)
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  plan        TenantPlan @default(FREE)
  logoUrl     String?
  phone       String?
  address     String?
  email       String?
  website     String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  config             TenantConfig?
  users              User[]
  pets               Pet[]
  appointments       Appointment[]
  products           Product[]
  productBatches     ProductBatch[]
  stockMovements     StockMovement[]
  orders             Order[]
  payments           Payment[]
  orderItems         OrderItem[]
  adoptions          Adoption[]
  adoptionAnimals    AdoptionAnimal[]
  notifications      Notification[]
  AuditLog           AuditLog[]
  clinicHours             ClinicHours[]
  staffSchedules          StaffSchedule[]
  blocks                 Block[]
  holidays               Holiday[]
  notificationTemplates  NotificationTemplate[]
  discounts              Discount[]
  branches               Branch[]
  cashRegisters          CashRegister[]
  posTickets             PosTicket[]
  posRefunds             PosRefund[]
  petConsents            PetConsent[]    @relation("PetConsentTenant")
  petConsentShares       PetConsentShare[] @relation("PetConsentShareTenant")
  petConsentAudits       PetConsentAudit[] @relation("PetConsentAuditTenant")
  consentTokens          ConsentToken[]  @relation("ConsentTokenTenant")
  consentAccessLogs      ConsentAccessLog[] @relation("ConsentAccessLogTenant")
  membershipPlans         MembershipPlan[] @relation("MembershipPlanTenant")
  membershipSubscriptions MembershipSubscription[] @relation("MembershipSubscriptionTenant")
  billingAttempts        BillingAttempt[] @relation("BillingAttemptTenant")
  vaccinationCampaigns       VaccinationCampaign[]        @relation("VaccinationCampaignTenant")
  vaccinationRegistrations   VaccinationRegistration[]   @relation("VaccinationRegistrationTenant")

  @@map("tenants")
}

model TenantConfig {
  id                       String   @id @default(uuid())
  tenantId                 String   @unique
  billingApiKey            String?
  billingApiSecret         String?
  billingEstablishmentCode String?  @default("001")
  billingEmissionPointCode String?  @default("001")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// ─── Sucursales ───────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  website   String?
  isMain    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          User[]
  appointments   Appointment[]
  clinicHours    ClinicHours[]
  staffSchedules StaffSchedule[]
  blocks         Block[]
  holidays       Holiday[]
  cashRegisters  CashRegister[]
  posTickets     PosTicket[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  branchId     String?
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role            UserRole
  identification  String?
  phone           String?
  billingAddress  String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  pushToken       String?
  emailVerified   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant                  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                  Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  pets                    Pet[]                   @relation("PetOwner")
  vetAppointments         Appointment[]           @relation("AppointmentVet")
  groomerAppointments     Appointment[]           @relation("AppointmentGroomer")
  medicalRecords          MedicalRecord[]
  vaccinations            Vaccination[]
  aestheticServices       AestheticService[]
  surgeries               Surgery[]
  orders                  Order[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  staffSchedules          StaffSchedule[]
  blocks                  Block[]
  cashRegistersOpened     CashRegister[]  @relation("CashRegisterOpenedBy")
  cashRegistersClosed     CashRegister[]  @relation("CashRegisterClosedBy")
  posTicketsCreated       PosTicket[]     @relation("PosTicketCreatedBy")
  posClientTickets        PosTicket[]     @relation("PosTicketClient")
  posRefunds              PosRefund[]     @relation("PosRefundBy")
  ownedConsents           PetConsent[]    @relation("PetConsentOwner")
  ownedConsentShares      PetConsentShare[] @relation("PetConsentShareOwner")
  consentAudits           PetConsentAudit[] @relation("PetConsentAuditActor")
  ownedConsentTokens      ConsentToken[]      @relation("ConsentTokenOwner")
  accessedConsentLogs     ConsentAccessLog[]  @relation("ConsentAccessLogAccessedBy")
  ownedMemberships        MembershipSubscription[] @relation("MembershipSubscriptionOwner")
  vaccinationCampaignsCreated VaccinationCampaign[]       @relation("VaccinationCampaignCreatedBy")
  vaccinationRegistrations   VaccinationRegistration[]  @relation("VaccinationRegistrationOwner")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([branchId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model Pet {
  id          String     @id @default(uuid())
  tenantId    String
  ownerId     String
  name        String
  species     PetSpecies
  breed       String?
  sex         PetSex
  birthDate   DateTime?
  weight      Float?
  photoUrl    String?
  microchip   String?
  color       String?
  isNeutered  Boolean    @default(false)
  allergies   String?
  notes       String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           User               @relation("PetOwner", fields: [ownerId], references: [id])
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  vaccinations    Vaccination[]
  aestheticServices AestheticService[]
  surgeries       Surgery[]
  adoptions       Adoption[]
  consents        PetConsent[]
  consentShares   PetConsentShare[]
  membershipSubscriptions MembershipSubscription[]
  vaccinationRegistrations VaccinationRegistration[]

  @@index([tenantId])
  @@index([ownerId])
  @@map("pets")
}

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String
  branchId        String?
  petId           String
  vetId           String?
  groomerId       String?
  type            AppointmentType
  status          AppointmentStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  notes           String?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  pet           Pet             @relation(fields: [petId], references: [id])
  vet           User?           @relation("AppointmentVet", fields: [vetId], references: [id])
  groomer       User?           @relation("AppointmentGroomer", fields: [groomerId], references: [id])
  medicalRecord MedicalRecord?
  vaccination   Vaccination?
  aesthetic     AestheticService?
  surgery       Surgery?
  auditLogs     AppointmentAuditLog[]

  @@index([tenantId])
  @@index([branchId])
  @@index([petId])
  @@index([vetId])
  @@index([groomerId])
  @@index([scheduledAt])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
  @@map("appointments")
}

model ClinicHours {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  dayOfWeek Int      // 0=Sun, 6=Sat
  openTime  String   // "09:00"
  closeTime String   // "17:00"
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, dayOfWeek])
  @@index([tenantId])
  @@index([branchId])
  @@map("clinic_hours")
}

model StaffSchedule {
  id          String   @id @default(uuid())
  tenantId    String
  branchId    String?
  userId      String
  dayOfWeek   Int      // 0-6
  startTime   String   // "09:00"
  endTime     String   // "17:00"
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, userId, dayOfWeek])
  @@index([tenantId])
  @@index([branchId])
  @@index([userId])
  @@map("staff_schedules")
}

model Block {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  userId    String?  // null = clinic-wide block
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([branchId])
  @@index([userId])
  @@index([startAt])
  @@map("blocks")
}

model Holiday {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  date      DateTime @db.Date
  name      String?
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, date])
  @@index([tenantId])
  @@index([branchId])
  @@map("holidays")
}

model AppointmentAuditLog {
  id             String            @id @default(uuid())
  appointmentId  String
  fromStatus     AppointmentStatus?
  toStatus       AppointmentStatus
  changedBy      String?
  createdAt      DateTime          @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_audit_logs")
}

model MedicalRecord {
  id             String   @id @default(uuid())
  tenantId       String
  petId          String
  vetId          String
  appointmentId  String?  @unique
  chiefComplaint String
  diagnosis      String
  treatment      String
  prescriptions  String?
  notes          String?
  attachments    String[]  // legacy URLs; prefer fileAttachments
  weight         Float?
  temperature    Float?
  heartRate      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pet              Pet                     @relation(fields: [petId], references: [id])
  vet              User                     @relation(fields: [vetId], references: [id])
  appointment      Appointment?            @relation(fields: [appointmentId], references: [id])
  fileAttachments  MedicalRecordAttachment[]

  @@index([petId])
  @@index([vetId])
  @@index([tenantId])
  @@map("medical_records")
}

model MedicalRecordAttachment {
  id           String   @id @default(uuid())
  tenantId     String
  medicalRecordId String
  key          String   // S3 key
  filename     String
  contentType  String
  size         Int      // bytes
  uploadedBy   String
  createdAt    DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([medicalRecordId])
  @@map("medical_record_attachments")
}

model Vaccination {
  id             String            @id @default(uuid())
  tenantId       String
  petId          String
  vetId          String
  appointmentId  String?           @unique
  vaccineName    String
  manufacturer   String?
  batchNumber    String?
  dose           Int               @default(1)
  administeredAt DateTime
  nextDueAt      DateTime?
  status         VaccinationStatus @default(ADMINISTERED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  pet         Pet          @relation(fields: [petId], references: [id])
  vet         User         @relation(fields: [vetId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([petId])
  @@index([vetId])
  @@index([nextDueAt])
  @@index([tenantId, nextDueAt])
  @@map("vaccinations")
}

model AestheticService {
  id            String          @id @default(uuid())
  tenantId      String
  petId         String
  groomerId     String
  appointmentId String?         @unique
  serviceName   String
  status        AestheticStatus @default(SCHEDULED)
  scheduledAt   DateTime
  price         Float?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  pet         Pet          @relation(fields: [petId], references: [id])
  groomer     User         @relation(fields: [groomerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([petId])
  @@index([groomerId])
  @@map("aesthetic_services")
}

model Surgery {
  id                String        @id @default(uuid())
  tenantId          String
  petId             String
  vetId             String
  appointmentId     String?       @unique
  type              String
  status            SurgeryStatus @default(SCHEDULED)
  scheduledAt       DateTime
  consentSignedAt   DateTime?
  consentSignedBy   String?
  preInstructions   String?
  postInstructions  String?
  postOpNotes       String?
  notes             String?
  anesthesiaType    String?
  durationMinutes   Int?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  pet         Pet          @relation(fields: [petId], references: [id])
  vet         User         @relation(fields: [vetId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([petId])
  @@index([vetId])
  @@map("surgeries")
}

model Product {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  sku               String
  description       String?
  category          String
  price             Float
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  imageUrl          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  batches        ProductBatch[]
  posItems       PosTicketItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, category])
  @@map("products")
}

model ProductBatch {
  id           String    @id @default(uuid())
  tenantId     String
  productId    String
  batchNumber  String
  quantity     Int
  expiryDate   DateTime? @db.Date
  createdAt    DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@index([expiryDate])
  @@map("product_batches")
}

model StockMovement {
  id        String            @id @default(uuid())
  tenantId  String
  productId String
  type      StockMovementType
  quantity  Int
  reason    String?
  userId    String?
  createdAt DateTime          @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@map("stock_movements")
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String
  clientId       String
  subtotal       Float
  discount       Float       @default(0)
  tax            Float       @default(0)
  total          Float
  status         OrderStatus @default(PENDING)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client         User           @relation(fields: [clientId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  discountUsages DiscountUsage[]

  @@index([tenantId])
  @@index([clientId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id          String        @id @default(uuid())
  tenantId    String
  orderId     String
  amount      Float
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  externalId  String?       // id from payment provider (no real integration)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("payments")
}

model OrderItem {
  id        String @id @default(uuid())
  tenantId  String
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  total     Float

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model AdoptionAnimal {
  id            String     @id @default(uuid())
  tenantId      String
  name          String
  species       PetSpecies
  breed         String?
  sex           PetSex
  birthDate     DateTime?
  color         String?
  weight        Float?
  photoUrl      String?
  description   String?
  isNeutered    Boolean    @default(false)
  notes         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adoptions Adoption[]

  @@index([tenantId])
  @@map("adoption_animals")
}

model Adoption {
  id                String         @id @default(uuid())
  tenantId          String
  petId             String?
  adoptionAnimalId  String?
  applicantId       String?
  status            AdoptionStatus @default(AVAILABLE)
  applicantName     String?
  applicantEmail    String?
  applicantPhone    String?
  notes             String?
  rejectionReason   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pet             Pet?            @relation(fields: [petId], references: [id])
  adoptionAnimal  AdoptionAnimal? @relation(fields: [adoptionAnimalId], references: [id])

  @@index([tenantId])
  @@index([petId])
  @@index([adoptionAnimalId])
  @@index([status])
  @@map("adoptions")
}

// ─── Pasaporte médico · consentimiento entre clínicas (Fase 1) ────────────────

model PetConsent {
  id               String         @id @default(uuid())
  tenantId         String         // source tenant (la clínica dueña del expediente)
  sourceTenantId   String         // denormalizado; coincide con tenantId
  petId            String
  ownerId          String         // User con rol CLIENT que concede el acceso
  targetTenantId   String         // tenant que recibe acceso de lectura
  targetClinicName String?        // capturado al momento del grant (sobrevive renames)
  status           ConsentStatus  @default(GRANTED)
  scopes           ConsentScope[] @default([PASSPORT_READ])
  message          String?        // nota opcional del dueño
  grantedAt        DateTime       @default(now())
  expiresAt        DateTime?      // null = sin expiración
  revokedAt        DateTime?
  revokeReason     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner  User   @relation("PetConsentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("PetConsentTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  audits PetConsentAudit[]

  @@index([tenantId])
  @@index([petId])
  @@index([ownerId])
  @@index([targetTenantId])
  @@index([status])
  @@index([expiresAt])
  @@index([petId, targetTenantId, status])
  @@map("pet_consents")
}

model PetConsentShare {
  id              String    @id @default(uuid())
  tenantId        String    // source tenant
  petId           String
  ownerId         String
  token           String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  lastAccessedAt  DateTime?
  accessCount     Int       @default(0)
  createdAt       DateTime  @default(now())

  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner  User   @relation("PetConsentShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tenant Tenant @relation("PetConsentShareTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  audits PetConsentAudit[]

  @@index([tenantId])
  @@index([petId])
  @@index([ownerId])
  @@index([expiresAt])
  @@map("pet_consent_shares")
}

model PetConsentAudit {
  id              String             @id @default(uuid())
  tenantId        String             // source tenant (contexto de auditoría)
  consentId       String?            // nulo para acciones sobre share
  shareId         String?
  action          ConsentAuditAction
  actorUserId     String?
  actorTenantId   String?
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime           @default(now())

  consent PetConsent?      @relation(fields: [consentId], references: [id], onDelete: Cascade)
  share   PetConsentShare? @relation(fields: [shareId], references: [id], onDelete: Cascade)
  tenant  Tenant @relation("PetConsentAuditTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  actor   User?  @relation("PetConsentAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([consentId])
  @@index([shareId])
  @@index([action])
  @@index([createdAt])
  @@map("pet_consent_audits")
}

// ─── Consent tokens (Fase 2) ──────────────────────────────────────────────────
// Token emitido por el dueño de la mascota para autorizar acceso a terceros
// identificados por email (no requieren cuenta en la misma clínica).
// Modelo complementario a PetConsent (que es clinic-to-clinic).

model ConsentToken {
  id              String             @id @default(uuid())
  tenantId        String             // source tenant (clínica dueña del expediente)
  ownerUserId     String             // User con rol CLIENT que emite el token
  granteeEmail    String             // email del tercero autorizado
  granteeTenantId String?            // tenant del tercero si ya es cliente conocido (cross-tenant)
  scope           ConsentTokenScope  @default(READ)
  petIds          String[]           // ids de Pet incluidos en la autorización
  status          ConsentTokenStatus @default(ACTIVE)
  expiresAt       DateTime           // fecha límite de validez
  createdAt       DateTime           @default(now())
  revokedAt       DateTime?          // timestamp de revocación si aplica
  auditReason     String?            // motivo capturado al crear/revocar (libre)

  owner      User               @relation("ConsentTokenOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation("ConsentTokenTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  accessLogs ConsentAccessLog[]

  @@index([tenantId, ownerUserId])
  @@index([tenantId, granteeEmail])
  @@index([tenantId, status])
  @@index([expiresAt])
  @@map("consent_tokens")
}

model ConsentAccessLog {
  id                 String             @id @default(uuid())
  tenantId           String             // source tenant (contexto de auditoría)
  consentTokenId     String
  accessedByUserId   String             // User que intentó/ejecutó la acción
  accessedByTenantId String?            // tenant del actor; null si no pertenece a ningún tenant conocido
  action             ConsentAccessAction
  ipAddress          String?
  userAgent          String?
  createdAt          DateTime           @default(now())

  consentToken ConsentToken @relation(fields: [consentTokenId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation("ConsentAccessLogTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  accessedBy   User         @relation("ConsentAccessLogAccessedBy", fields: [accessedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([consentTokenId])
  @@index([accessedByUserId])
  @@index([tenantId, action])
  @@index([createdAt])
  @@map("consent_access_logs")
}

model Notification {
  id        String              @id @default(uuid())
  tenantId  String
  userId    String
  title     String
  body      String
  channel   NotificationChannel
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([readAt])
  @@map("notifications")
}

model NotificationTemplate {
  id           String              @id @default(uuid())
  tenantId     String?              // null = system template
  key          String               // e.g. appointment_reminder
  channel      NotificationChannel
  subject      String?              // for email
  bodyTemplate String               // handlebars-style placeholders
  isSystem     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, channel])
  @@index([tenantId])
  @@map("notification_templates")
}

model Discount {
  id          String             @id @default(uuid())
  tenantId    String
  name        String
  description String?
  type        DiscountType
  value       Float              @default(0) // porcentaje (0-100) o monto fijo; 0 si type=BUY_X_GET_Y
  buyQuantity Int?               // unidades a comprar (ej: 2 en un 2x1)
  getQuantity Int?               // unidades gratis    (ej: 1 en un 2x1)
  targetType  DiscountTargetType
  targetId    String?            // productId si targetType = PRODUCT
  category    String?            // categoría si targetType = PRODUCT_CATEGORY
  serviceType String?            // AppointmentType si targetType = SERVICE
  minAmount   Float?             // monto mínimo de compra para aplicar
  maxUses     Int?               // null = usos ilimitados
  usedCount   Int                @default(0)
  startAt     DateTime           // fecha de activación
  endAt       DateTime?          // null = sin expiración
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usages     DiscountUsage[]

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@index([tenantId, isActive])
  @@map("discounts")
}

model DiscountUsage {
  id          String   @id @default(uuid())
  tenantId    String
  discountId  String
  orderId     String?
  posTicketId String?
  savedAmount Float
  createdAt   DateTime @default(now())

  discount  Discount  @relation(fields: [discountId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  posTicket PosTicket? @relation(fields: [posTicketId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([discountId])
  @@index([orderId])
  @@index([posTicketId])
  @@map("discount_usages")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─── Punto de Venta (POS) ────────────────────────────────────────────────────

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum PosTicketStatus {
  OPEN
  COMPLETED
  REFUNDED
  PARTIAL_REFUND
  CANCELLED
}

enum PosItemType {
  PRODUCT
  SERVICE
}

model CashRegister {
  id             String             @id @default(uuid())
  tenantId       String
  branchId       String?
  openedById     String
  closedById     String?
  status         CashRegisterStatus @default(OPEN)
  openingBalance Float              @default(0)
  closingBalance Float?
  notes          String?
  openedAt       DateTime           @default(now())
  closedAt       DateTime?

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch? @relation(fields: [branchId], references: [id])
  openedBy User    @relation("CashRegisterOpenedBy", fields: [openedById], references: [id])
  closedBy User?   @relation("CashRegisterClosedBy", fields: [closedById], references: [id])
  tickets  PosTicket[]

  @@index([tenantId])
  @@index([branchId])
  @@index([openedById])
  @@index([tenantId, status])
  @@map("cash_registers")
}

model PosTicket {
  id          String          @id @default(uuid())
  tenantId    String
  branchId    String?
  registerId  String?
  clientId    String?         // optional: User with role CLIENT
  subtotal    Float
  discount    Float           @default(0)
  tax         Float           @default(0)
  total       Float
  providerInvoiceId String?
  invoiceStatus     String?
  invoiceNumber     String?
  invoiceAccessKey  String?
  invoiceIssuedAt   DateTime?
  invoiceAuthorizedAt DateTime?
  notes       String?
  status      PosTicketStatus @default(OPEN)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch?       @relation(fields: [branchId], references: [id])
  register  CashRegister? @relation(fields: [registerId], references: [id])
  client    User?         @relation("PosTicketClient", fields: [clientId], references: [id])
  createdBy User          @relation("PosTicketCreatedBy", fields: [createdById], references: [id])
  items     PosTicketItem[]
  payments  PosPayment[]
  refunds   PosRefund[]
  discountUsages DiscountUsage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, clientId])
  @@index([tenantId, providerInvoiceId])
  @@index([registerId])
  @@map("pos_tickets")
}

model PosTicketItem {
  id             String      @id @default(uuid())
  ticketId       String
  type           PosItemType
  productId      String?
  description    String
  quantity       Float       @default(1)
  unitPrice      Float
  discountAmount Float       @default(0)
  total          Float

  ticket  PosTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product Product?  @relation(fields: [productId], references: [id])

  @@index([ticketId])
  @@index([productId])
  @@map("pos_ticket_items")
}

model PosPayment {
  id        String        @id @default(uuid())
  ticketId  String
  method    PaymentMethod
  amount    Float
  reference String?
  createdAt DateTime      @default(now())

  ticket PosTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("pos_payments")
}

model PosRefund {
  id           String   @id @default(uuid())
  ticketId     String
  tenantId     String
  amount       Float
  reason       String?
  refundedById String
  createdAt    DateTime @default(now())

  ticket     PosTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refundedBy User      @relation("PosRefundBy", fields: [refundedById], references: [id])

  @@index([tenantId])
  @@index([ticketId])
  @@map("pos_refunds")
}

// ─── Fase 2 · Membresías (modelos) ────────────────────────────────────────────

model MembershipPlan {
  id                String                  @id @default(uuid())
  tenantId          String                  // clínica dueña del catálogo
  slug              String                  // slug único por tenant para URLs públicas
  name              String
  description       String?
  priceCents        Int                     // en centavos para evitar floats
  currency          String                  @default("USD")
  billingPeriod     MembershipBillingPeriod @default(MONTHLY)
  includedBenefits  String[]                @default([]) // bullets cortos: "1 consulta/mes", "10% grooming", etc.
  applicableSpecies PetSpecies[]            @default([]) // [] = aplica a cualquier especie
  isActive          Boolean                 @default(true)
  displayOrder      Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  tenant        Tenant                 @relation("MembershipPlanTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions MembershipSubscription[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("membership_plans")
}

model MembershipSubscription {
  id                 String                      @id @default(uuid())
  tenantId           String                      // tenant del catálogo (donde vive el plan)
  sourceTenantId     String                      // tenant del dueño de la mascota
  petId              String
  ownerId            String
  planId             String
  status             MembershipSubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingAt      DateTime
  autoRenew          Boolean                      @default(true)
  paymentMethodToken String?                     // token opaco del BillingProvider (no PII/PII)
  canceledAt         DateTime?
  cancelReason       String?
  lastChargedAt      DateTime?
  lastChargeTxId     String?                     // id de transacción del último cobro exitoso
  providerKind       BillingProviderKind         @default(MOCK)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  tenant          Tenant           @relation("MembershipSubscriptionTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  pet             Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner           User             @relation("MembershipSubscriptionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  plan            MembershipPlan   @relation(fields: [planId], references: [id])
  billingAttempts BillingAttempt[]

  @@unique([petId, planId])
  @@index([tenantId])
  @@index([sourceTenantId])
  @@index([ownerId])
  @@index([status])
  @@index([nextBillingAt])
  @@map("membership_subscriptions")
}

model BillingAttempt {
  id             String                @id @default(uuid())
  tenantId       String                // source tenant del contexto de cobro
  subscriptionId String
  provider       BillingProviderKind
  transactionId  String?               // id devuelto por el provider
  status         BillingAttemptStatus
  amountCents    Int
  currency       String
  failureCode    String?
  failureMessage String?
  createdAt      DateTime              @default(now())

  tenant       Tenant                @relation("BillingAttemptTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  subscription MembershipSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
  @@map("billing_attempts")
}

// ─── Fase 3 · Campañas de vacunación ─────────────────────────────────────────

enum VaccinationCampaignStatus {
  DRAFT     // staff la está armando, no visible al cliente
  OPEN      // abierta para inscripciones de mascotas
  CLOSED    // cerrada: no más inscripciones, aún no ejecutada
  COMPLETED // ejecutada, registros cerrados
  CANCELLED // cancelada
}

enum VaccinationRegistrationStatus {
  REGISTERED // el dueño inscribió a la mascota
  ATTENDED   // la mascota recibió la vacuna en la fecha de la campaña
  NO_SHOW    // el dueño no llevó a la mascota
  CANCELLED  // inscripción cancelada
}

model VaccinationCampaign {
  id             String                    @id @default(uuid())
  tenantId       String                    // clínica que organiza la campaña
  name           String
  description    String?
  vaccineName    String                    // ej: "Antirrábica", "Parvovirus", "Quíntuple"
  startsAt       DateTime
  endsAt         DateTime
  location       String?                   // dirección / sede de la jornada
  capacity       Int?                      // cupos disponibles (null = sin tope)
  priceCents     Int                       @default(0) // 0 = gratuita
  currency       String                    @default("USD")
  status         VaccinationCampaignStatus @default(DRAFT)
  notes          String?                   // instrucciones para el dueño
  createdById     String                    // staff que la creó
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant        Tenant                          @relation("VaccinationCampaignTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User                            @relation("VaccinationCampaignCreatedBy", fields: [createdById], references: [id])
  registrations VaccinationRegistration[]

  @@index([tenantId, status])
  @@index([tenantId, startsAt])
  @@map("vaccination_campaigns")
}

model VaccinationRegistration {
  id           String                         @id @default(uuid())
  tenantId     String                         // denormalizado para que el middleware de tenant no tenga que saltar por la relación campaign
  campaignId   String
  petId        String
  ownerId      String
  status       VaccinationRegistrationStatus  @default(REGISTERED)
  attendedAt   DateTime?
  notes        String?                        // observaciones del staff el día de la jornada
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt

  campaign VaccinationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pet      Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner    User                @relation("VaccinationRegistrationOwner", fields: [ownerId], references: [id])
  tenant   Tenant              @relation("VaccinationRegistrationTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, petId])
  @@index([tenantId])
  @@index([campaignId, status])
  @@index([petId])
  @@index([ownerId])
  @@map("vaccination_registrations")
}
