# =============================================================================
# NuVet – Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for any (dev only).
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Feature Flags ─────────────────────────────────────────────────────────────
# CSV list of enabled feature flags
FEATURE_FLAGS=clinical_reminders_manual_trigger,clinical_reminders_scheduler
# Optional JSON map. CSV takes precedence when both are defined.
FEATURE_FLAGS_JSON={"clinical_reminders_manual_trigger":true,"clinical_reminders_scheduler":true}

# ── Schedulers ────────────────────────────────────────────────────────────────
CLINICAL_REMINDERS_CRON=0 */2 * * *
CLINICAL_REMINDERS_TIMEZONE=America/Guayaquil

# ── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=nuvet-files

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@nuvet.app
SMTP_PASS=smtp_password
SMTP_FROM="NuVet <noreply@nuvet.app>"

# ── Expo Push Notifications ───────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001


# ── Backup / Restore Ops ─────────────────────────────────────────────────────
BACKUP_DIR=./backups
DRILL_DATABASE_URL=postgresql://nuvet:nuvet_secret@localhost:5432/nuvet_db_drill?schema=public

# ── Billing / Electronic Invoicing (Faktur) ──────────────────────────────────
# Base URL de la API de Faktur
BILLING_FAKTUR_API_BASE_URL=https://api.faktur.com.ec
# Credenciales (formato sk_...)
BILLING_FAKTUR_API_KEY=sk_your_api_key
BILLING_FAKTUR_API_SECRET=your_api_secret
# Timeout en ms para llamadas a Faktur
BILLING_FAKTUR_TIMEOUT_MS=12000
# Tipo de API Key: POINT (por punto de emisión) o COMPANY (por empresa)
BILLING_FAKTUR_KEY_MODE=COMPANY
# Códigos de establecimiento y punto de emisión (3 dígitos, obligatorio si KEY_MODE=COMPANY)# Código de impuesto IVA (2 = IVA, default)
BILLING_FAKTUR_TAX_CODE=2
# Código de tarifa IVA (2 = IVA 15%, default)
BILLING_FAKTUR_IVA_RATE_CODE=2
# Emisión asíncrona por defecto (true/false)
BILLING_FAKTUR_ASYNC_EMISSION=false

