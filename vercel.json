{
    "version": 2,
    "installCommand": "pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm prisma generate && pnpm run build",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
