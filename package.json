{
  "name": "@nuvet/api",
  "version": "1.0.0",
  "description": "NuVet API",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "multer": "^2.2.0",
      "brace-expansion": "^5.0.6",
      "js-yaml": "^4.2.0",
      "@babel/core": "^7.29.6",
      "qs": "^6.15.2"
    }
  },
  "scripts": {
    "build:types": "tsc -p types/tsconfig.json",
    "postinstall": "prisma generate",
    "build": "pnpm run build:types && pnpm prisma:migrate:deploy && nest build && nest build --webpack --webpackPath webpack-lambda.config.js && node scripts/prepare-vercel.js",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "prisma:seed:full": "ts-node --project tsconfig.seed.json prisma/seed.full.ts",
    "ops:backup": "bash ./scripts/backup-db.sh",
    "ops:restore": "bash ./scripts/restore-db.sh",
    "ops:drill": "bash ./scripts/drill-backup-restore.sh"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nuvet/types": "link:types",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@nestjs/testing": "^11.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.39.3",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "webpack-node-externals": "^3.0.0"
  }
}
