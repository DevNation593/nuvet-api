{
  "include": [
    "src/**/*"
  ],
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "declarationMap": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src",
    "sourceMap": false,
    "declaration": true
  }
}